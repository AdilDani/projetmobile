<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Cards -->
    <style name="Card">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">@dimen/space_l</item>
    </style>

    <!-- Toolbar title -->
    <style name="ToolbarTitle">
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Text styles -->
    <style name="TextDisplay">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextHeadline">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextSubtitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextBody">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="TextSecondary">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_small</item>
    </style>

    <style name="TextCaption">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <style name="SectionLabel">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">@dimen/space_l</item>
        <item name="android:layout_marginBottom">@dimen/space_s</item>
    </style>

    <!-- Buttons -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_m</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="DangerButton" parent="PrimaryButton">
        <item name="backgroundTint">@color/danger</item>
    </style>

    <style name="OutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="cornerRadius">@dimen/radius_m</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Inputs -->
    <style name="Input">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/input_height</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:paddingStart">@dimen/space_l</item>
        <item name="android:paddingEnd">@dimen/space_l</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="FieldLabel">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:layout_marginBottom">@dimen/space_xs</item>
        <item name="android:layout_marginTop">@dimen/space_m</item>
    </style>
</resources>
