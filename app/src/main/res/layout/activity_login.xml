<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_pale_2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="@dimen/space_xxl">

        <ImageView
            android:layout_width="@dimen/avatar_l"
            android:layout_height="@dimen/avatar_l"
            android:layout_marginTop="@dimen/space_xxxl"
            android:src="@drawable/ic_logo"
            android:contentDescription="@string/cd_logo" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/space_m">

            <TextView
                style="@style/TextHeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_fleet"
                android:textColor="@color/text_primary" />

            <TextView
                style="@style/TextHeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/brand_tracking"
                android:textColor="@color/primary" />
        </LinearLayout>

        <TextView
            style="@style/TextSecondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/tagline_admin" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xxxl"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/space_xl"
            android:elevation="@dimen/elevation_card">

            <TextView
                style="@style/TextTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_title" />

            <TextView
                style="@style/FieldLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_role_question" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_role"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_role_admin"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/role_admin"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_role_chauffeur"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/role_chauffeur"
                    android:textAllCaps="false" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <EditText
                android:id="@+id/input_email"
                style="@style/Input"
                android:layout_marginTop="@dimen/space_l"
                android:hint="@string/login_email_hint"
                android:inputType="textEmailAddress"
                android:drawableStart="@drawable/ic_email"
                android:drawablePadding="@dimen/space_m"
                android:autofillHints="emailAddress" />

            <EditText
                android:id="@+id/input_password"
                style="@style/Input"
                android:layout_marginTop="@dimen/space_m"
                android:hint="@string/login_password_hint"
                android:inputType="textPassword"
                android:drawableStart="@drawable/ic_lock"
                android:drawablePadding="@dimen/space_m"
                android:autofillHints="password" />

            <CheckBox
                android:id="@+id/checkbox_remember"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/login_remember_me"
                android:textColor="@color/text_secondary"
                android:buttonTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login"
                style="@style/PrimaryButton"
                android:layout_marginTop="@dimen/space_l"
                android:text="@string/login_button" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
