<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/space_l">

        <TextView
            style="@style/ToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/my_position_title" />

        <ImageView
            android:layout_width="@dimen/icon_m"
            android:layout_height="@dimen/icon_m"
            android:src="@drawable/ic_more"
            android:tint="@color/white"
            android:contentDescription="@string/cd_profile" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.google.android.gms.maps.MapView
            android:id="@+id/map_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ImageView
            android:layout_width="@dimen/icon_xl"
            android:layout_height="@dimen/icon_xl"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/space_l"
            android:background="@drawable/bg_fab_white"
            android:padding="@dimen/space_m"
            android:src="@drawable/ic_locate"
            android:tint="@color/primary"
            android:elevation="@dimen/elevation_card"
            android:contentDescription="@string/cd_locate" />
    </FrameLayout>

    <!-- Real-time status card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="@dimen/space_l"
        android:elevation="@dimen/elevation_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                style="@style/TextSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/realtime_status" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_success"
                android:paddingStart="@dimen/space_m"
                android:paddingEnd="@dimen/space_m"
                android:paddingTop="@dimen/space_xs"
                android:paddingBottom="@dimen/space_xs"
                android:text="@string/status_running"
                android:textColor="@color/success"
                android:textSize="@dimen/text_small"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_last_update"
            style="@style/TextCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/realtime_status" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginTop="@dimen/space_m">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_metric_box"
                android:padding="@dimen/space_m"
                android:layout_marginEnd="@dimen/space_s">

                <TextView
                    style="@style/TextSecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/speed" />

                <TextView
                    style="@style/TextHeadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:text="@string/speed_sample" />

                <TextView
                    style="@style/TextCaption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/speed_unit" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_metric_box"
                android:padding="@dimen/space_m"
                android:layout_marginStart="@dimen/space_s">

                <TextView
                    style="@style/TextSecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/direction" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        style="@style/TextHeadline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/direction_ne" />

                    <ImageView
                        android:layout_width="@dimen/icon_s"
                        android:layout_height="@dimen/icon_s"
                        android:layout_marginStart="@dimen/space_s"
                        android:src="@drawable/ic_compass"
                        android:tint="@color/primary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_position"
            style="@style/PrimaryButton"
            android:layout_marginTop="@dimen/space_l"
            app:icon="@drawable/ic_play"
            app:iconGravity="textStart"
            app:iconTint="@color/white"
            android:text="@string/send_my_position" />
    </LinearLayout>
</LinearLayout>
