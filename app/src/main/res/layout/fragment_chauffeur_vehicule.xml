<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/space_l">

        <TextView
            style="@style/ToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/my_vehicle_title" />

        <ImageView
            android:layout_width="@dimen/icon_m"
            android:layout_height="@dimen/icon_m"
            android:src="@drawable/ic_more"
            android:tint="@color/white"
            android:contentDescription="@string/cd_profile" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_l">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="@dimen/img_vehicle_h"
                android:background="@drawable/bg_card"
                android:padding="@dimen/space_xl"
                android:src="@drawable/ic_truck"
                android:tint="@color/text_secondary"
                android:elevation="@dimen/elevation_card"
                android:contentDescription="@string/cd_vehicle_image" />

            <LinearLayout
                android:id="@+id/details_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/space_l"
                android:background="@drawable/bg_card"
                android:padding="@dimen/space_l"
                android:elevation="@dimen/elevation_card">

                <!-- rows are added programmatically -->
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
