<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/primary"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="@dimen/space_l"
    android:paddingBottom="@dimen/space_l"
    android:paddingStart="@dimen/space_l"
    android:paddingEnd="@dimen/space_l">

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="@dimen/icon_m"
        android:layout_height="@dimen/icon_m"
        android:src="@drawable/ic_back"
        android:contentDescription="@string/cd_back"
        android:tint="@color/white" />

    <TextView
        android:id="@+id/toolbar_title"
        style="@style/ToolbarTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/space_l"
        android:text="@string/app_name" />

    <ImageView
        android:id="@+id/btn_delete"
        android:layout_width="@dimen/icon_m"
        android:layout_height="@dimen/icon_m"
        android:layout_marginEnd="@dimen/space_l"
        android:src="@drawable/ic_delete"
        android:visibility="gone"
        android:contentDescription="Supprimer"
        android:tint="@color/white" />

    <ImageView
        android:id="@+id/btn_action"
        android:layout_width="@dimen/icon_m"
        android:layout_height="@dimen/icon_m"
        android:src="@drawable/ic_more"
        android:visibility="gone"
        android:contentDescription="@string/cd_profile"
        android:tint="@color/white" />
</LinearLayout>
