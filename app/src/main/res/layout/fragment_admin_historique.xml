<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <include layout="@layout/toolbar_admin" />

    <TextView
        style="@style/SectionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_l"
        android:layout_marginEnd="@dimen/space_l"
        android:text="@string/tab_trips" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_trajets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="@dimen/space_l"
        android:paddingEnd="@dimen/space_l"
        android:paddingBottom="@dimen/space_l" />
</LinearLayout>
