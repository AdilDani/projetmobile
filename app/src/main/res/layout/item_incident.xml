<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="@dimen/space_l"
    android:layout_marginBottom="@dimen/space_m">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="@dimen/avatar_s"
            android:layout_height="@dimen/avatar_s"
            android:background="@drawable/bg_circle_pale"
            android:padding="@dimen/space_s"
            android:src="@drawable/ic_warning"
            android:tint="@color/danger"
            android:contentDescription="@string/incidents_title" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_m"
            android:orientation="vertical">

            <TextView
                android:id="@+id/incident_type"
                style="@style/TextBody"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:text="@string/field_incident_type" />

            <TextView
                android:id="@+id/incident_vehicle"
                style="@style/TextSecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="@string/field_vehicle" />
        </LinearLayout>

        <TextView
            android:id="@+id/incident_status"
            style="@style/TextCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/space_m"
            android:paddingEnd="@dimen/space_m"
            android:paddingTop="@dimen/space_xs"
            android:paddingBottom="@dimen/space_xs"
            android:text="@string/tab_ongoing" />
    </LinearLayout>

    <TextView
        android:id="@+id/incident_description"
        style="@style/TextSecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_m"
        android:text="@string/field_description" />

    <TextView
        android:id="@+id/incident_date"
        style="@style/TextCaption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:text="@string/admin_date_sample" />
</LinearLayout>
