<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg">

    <include layout="@layout/toolbar_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_l">

            <!-- Today summary card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="@dimen/space_l"
                android:elevation="@dimen/elevation_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        style="@style/TextSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/today" />

                    <ImageView
                        android:layout_width="@dimen/icon_m"
                        android:layout_height="@dimen/icon_m"
                        android:src="@drawable/ic_calendar"
                        android:tint="@color/primary"
                        android:contentDescription="@string/today" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginTop="@dimen/space_l">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/stat_distance"
                            style="@style/TextHeadline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/metric_distance" />

                        <TextView
                            style="@style/TextCaption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/metric_distance" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/stat_duration"
                            style="@style/TextHeadline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/metric_duration" />

                        <TextView
                            style="@style/TextCaption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/metric_duration" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/stat_avg_speed"
                            style="@style/TextHeadline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/metric_avg_speed" />

                        <TextView
                            style="@style/TextCaption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/metric_avg_speed" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/card_image_h"
                    android:layout_marginTop="@dimen/space_l"
                    android:background="@drawable/bg_map_placeholder"
                    android:padding="@dimen/space_xl"
                    android:src="@drawable/ic_route"
                    android:tint="@color/primary"
                    android:contentDescription="@string/map_title" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/space_l"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="@dimen/dot_s"
                        android:layout_height="@dimen/dot_s"
                        android:background="@drawable/bg_circle_pale" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_m"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextBody"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:text="@string/trip_departure" />

                        <TextView
                            android:id="@+id/text_depart"
                            style="@style/TextSecondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/trip_departure" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_depart_time"
                        style="@style/TextBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="@string/trip_departure" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/space_m"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="@dimen/dot_s"
                        android:layout_height="@dimen/dot_s"
                        android:background="@drawable/bg_badge_red" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_m"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextBody"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:text="@string/trip_arrival" />

                        <TextView
                            android:id="@+id/text_arrival"
                            style="@style/TextSecondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/trip_arrival" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_arrival_time"
                        style="@style/TextBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="@string/trip_arrival" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/stroke_width"
                    android:layout_marginTop="@dimen/space_l"
                    android:background="@color/divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/space_m">

                    <TextView
                        style="@style/TextSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/trip_distance_covered" />

                    <TextView
                        android:id="@+id/text_total_distance"
                        style="@style/TextBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="@string/metric_distance" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/space_s">

                    <TextView
                        style="@style/TextSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/trip_total_time" />

                    <TextView
                        android:id="@+id/text_total_time"
                        style="@style/TextBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="@string/metric_duration" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/space_s">

                    <TextView
                        style="@style/TextSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/trip_estimated_consumption" />

                    <TextView
                        android:id="@+id/text_consumption"
                        style="@style/TextBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="@string/trip_estimated_consumption" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/history_trips_title" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_trips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
